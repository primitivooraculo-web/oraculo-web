ADMIN_AGENT_HOST=127.0.0.1
ADMIN_AGENT_PORT=4310
ADMIN_AGENT_TOKEN=REEMPLAZAR_TOKEN_LARGO

RCON_HOST=127.0.0.1
RCON_PORT=8888
RCON_PASSWORD=REEMPLAZAR_PASSWORD_RCON

ADMIN_AGENT_ALLOW_CONSOLE=false
ADMIN_AGENT_ACTIONS_ENABLED=false

# Compatibilidad PrimalCore observada. Se lee solo para estado/capacidades,
# no copia codigo interno ni modifica C:\PrimalCore.
PRIMALCORE_ENV_PATH=C:\PrimalCore\.env
PRIMALCORE_DB_HOST=127.0.0.1
PRIMALCORE_DB_PORT=3306
PRIMALCORE_DB_USER=oraculo_ro
PRIMALCORE_DB_PASSWORD=REEMPLAZAR_PASSWORD_LECTURA
PRIMALCORE_DB_NAME=primalcore

# Lectura read-only del mapa publicado. No toca ingest ni telemetria.
ORACULO_MAPA_LIVE_URL=https://www.oraculoprimitivo.xyz/api/oraculo/live
ORACULO_MAPA_TIMEOUT_MS=7000

# Opcional: plantillas para acciones avanzadas si ya conoces el comando exacto del servidor.
# Usa {steamId}, {x}, {y}, {z}, {species}, {skin}, {skinCode}, {reason}, {value},
# {growth}, {health}, {stamina}, {hunger}, {thirst}, {dietJson}, {vitaminsJson},
# {mutationsJson}, {snapshotJson}.
ADMIN_AGENT_CMD_KILL_DINO=
ADMIN_AGENT_CMD_RESTORE_DINO=
ADMIN_AGENT_CMD_TELEPORT=
ADMIN_AGENT_CMD_CHANGE_SKIN=
ADMIN_AGENT_CMD_WEATHER=

# Vault propio del Oraculo. No hereda el limite de 4 mutaciones de PrimalCore.
ORACULO_GARAGE_SAVE_MIN_GROWTH=0.75
ORACULO_GARAGE_REUSE_MAX_GROWTH=0.30
ORACULO_GARAGE_VAULT_PATH=

# Motor propio de skins/cosmeticos.
# La web debe apuntar ORACULO_COSMETICS_API_URL a la URL publica del agente.
ORACULO_SKINS_STORE_PATH=
ORACULO_SKIN_DEFAULT_TOKENS=0
ORACULO_SKIN_MAX_PRESETS=10
ORACULO_SKIN_PATTERN_COUNT=3
ORACULO_SKIN_QUEUE_MAX=500
ORACULO_SKIN_CLAIM_TIMEOUT_SECONDS=60
ORACULO_SKIN_MOD_TOKEN=REEMPLAZAR_TOKEN_SOLO_DEL_MOD
